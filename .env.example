# Optional — cloud sign-in and backup of saved calculations.
# The app is fully functional without these (local-first).
#
# To enable: create a Supabase project, run supabase/migrations/0001_init.sql,
# then copy this file to .env.local and fill in the values from
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
